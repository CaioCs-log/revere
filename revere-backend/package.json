{
  "name": "revere-backend",
  "version": "1.0.0",
  "description": "Backend for Revere Project using Firebase Functions",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "firebase-admin": "^13.2.0",
    "firebase-functions": "^6.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "firebase-functions-test": "^3.5.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.0.8"
  },
  "private": true
}
